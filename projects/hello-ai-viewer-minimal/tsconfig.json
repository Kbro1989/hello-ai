{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "node",
		"lib": ["ES2022", "DOM"],
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"allowImportingTsExtensions": false,
		"noEmit": false,
		"resolveJsonModule": true,
		"outDir": "dist"
	},
	"include": ["scripts/**/*.ts", "src/**/*.ts"]
}
