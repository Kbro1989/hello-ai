[gd_scene load_steps=5 format=2]

; A reusable NPC prefab with proximity-based voice interaction.
; 1. Drag this scene into your main world scene.
; 2. Select the 'ProximityArea' node and set the 'Npc Id' and 'Region' in the Inspector.
; 3. Adjust the 'Detection Radius' as needed.
; 4. Change the placeholder sprite in the 'Sprite' node.

[ext_resource path="res://ProximityVoice.gd" type="Script" id=1]
[ext_resource path="res://icon.png" type="Texture" id=2] ; Placeholder texture - Replace with actual ElderScape NPC sprite

[sub_resource type="CircleShape2D" id=1]
radius = 100.0 ; Default physics collision radius

[sub_resource type="CircleShape2D" id=2]
radius = 300.0 ; Default proximity detection radius, can be overridden by script export var

[node name="NpcPrefab" type="KinematicBody2D"]

[node name="Sprite" type="Sprite" parent="."]
texture = ExtResource( 2 )

[node name="CollisionShape2D" type="CollisionShape2D" parent="."]
shape = SubResource( 1 )

[node name="ProximityArea" type="Area2D" parent="."]
script = ExtResource( 1 )
detection_radius = 300.0
npc_id = "stormcrown_guard_1"
region = "Stormcrown Highlands"

[node name="CollisionShape2D" type="CollisionShape2D" parent="ProximityArea"]
shape = SubResource( 2 )

[node name="DialogueLabel" type="Label" parent="."]
margin_left = -50.0
margin_top = -80.0
margin_right = 50.0
margin_bottom = -60.0
align = 1
valign = 1
autowrap = true
__meta__ = {
"_edit_use_anchors_": false
}