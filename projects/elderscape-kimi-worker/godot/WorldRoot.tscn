[gd_scene load_steps=5 format=2]

; This is the root scene for the ElderScape multi-location starter world.
; It connects different regions and time layers (eras) via portals.

[ext_resource path="res://godot/Player.gd" type="Script" id=1]
[ext_resource path="res://godot/LocationNode.gd" type="Script" id=2]
[ext_resource path="res://godot/Portal.gd" type="Script" id=3]

[sub_resource type="RectangleShape2D" id=1]
extents = Vector2( 32, 32 )

[node name="WorldRoot" type="Node2D"]

[node name="Player" type="KinematicBody2D" parent="."]
position = Vector2(200, 300)
script = ExtResource( 1 )

[node name="CollisionShape2D" type="CollisionShape2D" parent="Player"]
shape = SubResource( 1 )

[node name="Camera2D" type="Camera2D" parent="Player"]
current = true

; =================================================================
; Region 1: Ashen Wastes
; =================================================================

[node name="Ashen_Wastes" type="Node2D" parent="."]
position = Vector2(0, 0)

[node name="Modern" type="Node2D" parent="Ashen_Wastes"]
script = ExtResource( 2 )
era_name = "Modern"
region_name = "Ashen Wastes"

[node name="Portal_to_DarkAges" type="Area2D" parent="Ashen_Wastes/Modern"]
position = Vector2(1000, 300)
script = ExtResource( 3 )
target_time_layer = "Dark Ages"
target_location_node = NodePath("../../DarkAges/Portal_to_Modern")

